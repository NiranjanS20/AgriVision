{
  "expo": {
    "name": "AgriVision",
    "slug": "agrivision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2F6B3B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2F6B3B"
      },
      "package": "com.iitb.agrivision"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "agrivision",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to scan leaves."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
